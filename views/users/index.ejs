<%- include('.../partials/header') %>

<div class="container my-4">
    <div class="alert aler-info">
        <p>
            This demo uses Node.js, Express, and EJS to show a List/View desgin pattern. The user list comes from a JSON file, and each entry loads a dyamic profile page. All images and data are placeholders
        </p>
    </div>

    <h2 class="mb-4">User Directory</h2>

    <table class="table table-hover table-striped">
        <thead class="thead-dark">
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(function(user){ %>
                <tr>
                    <td><a href="/users/view/<%= user.id %>"><%= user.first_name %></a></td>
                    <td><%= user.last_name %></td>
                    <td><%= user.email %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>